{
  "expo": {
    "name": "TrackIt",
    "slug": "MONEY_MANAGER",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "moneymanager",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kavindukp.MONEY_MANAGER"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Money Manager needs camera access to scan receipts and bills.",
          "photosPermission": "Money Manager needs photo access to attach receipt images."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8ef29841-20ee-435f-a8f3-06a86a7c7c6c"
      }
    }
  }
}